# ---------------------------------------------------------------------------
# rutracker-torrent-mcp — environment configuration
# ---------------------------------------------------------------------------

# rutracker.org account. The client signs in on first use and stores the
# session cookie; subsequent restarts reuse the cookie until it expires.
RUTRACKER_LOGIN=
RUTRACKER_PASSWORD=

# Optional: path to a persisted cookie jar (JSON). Useful when rutracker
# demands a captcha on fresh login — you can sign in manually in a browser,
# export the `bb_session` cookie, and drop it here to bypass the captcha.
# Defaults to '.cache/cookies.json'.
# RUTRACKER_COOKIES_PATH=.cache/cookies.json

# Optional upstream proxy (SOCKS5 / HTTP) for reaching rutracker.org.
# Only needed if the host network can't hit the site directly.
# RUTRACKER_PROXY_URL=socks5://user:pass@host:1080

# Base URL. Defaults to https://rutracker.org (main site). Override to a
# mirror (rutracker.net / rutracker.nl) only as a fallback.
# RUTRACKER_BASE_URL=https://rutracker.org

# --- MCP transport ---------------------------------------------------------

# Bearer token for HTTP transports. Shared across movie_handler services.
MCP_AUTH_TOKEN=

# MCP_TRANSPORT=stdio
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=8767

# --- Caching ---------------------------------------------------------------

# CACHE_PATH=.cache/rutracker.sqlite
# CACHE_TTL_SEARCH_SECONDS=3600      # 1 hour
# CACHE_TTL_TORRENT_SECONDS=86400    # 24 hours
